# AFL Predictor Configuration
# Copy this file to .env and fill in your values

# LLM API Keys (at least one required for LLM features)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The Odds API (for bookmaker odds)
ODDS_API_KEY=your_odds_api_key_here

# Betting Configuration
INITIAL_BANKROLL=1000.0
KELLY_FRACTION=0.25
MAX_BET_FRACTION=0.05
MIN_EV_THRESHOLD=0.05

# Model Configuration
RETRAIN_EVERY_N_ROUNDS=4
WARMSTART_TREES=5
WARMSTART_LR=0.01
ELO_K_FACTOR=40.0
ELO_HOME_ADVANTAGE=35.0
ELO_SEASON_REGRESSION=0.3

# Data Configuration
DATA_START_YEAR=2018
CURRENT_SEASON=2026
